# Copy to frontend/.env for local development (Vite loads .env automatically).
# Backend must be running, e.g. uvicorn app.main:app --reload --port 8000 (from backend/)

VITE_API_BASE_URL=http://localhost:8000

# Optional: only needed for embedded map view on route result page
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_GOOGLE_MAPS_BROWSER_KEY=
