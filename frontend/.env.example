# Local dev: leave unset — Vite proxies to http://127.0.0.1:8000 (see vite.config.ts).
#
# Render / production build: set at build time (Render Dashboard or render.yaml):
# VITE_API_BASE_URL=https://eldergo-kl-api.onrender.com
#
# If unset in production, the app falls back to https://eldergo-kl-api.onrender.com

# Optional: only needed for embedded map view on route result page
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_GOOGLE_MAPS_BROWSER_KEY=
