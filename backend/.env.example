# Copy to backend/.env and fill in values. Never commit real secrets.
# Use lowercase `.env` (recommended). `.ENV` is also supported on case-sensitive filesystems.

# Core
ELDERGO_ENV=development
ELDERGO_DEMO_MODE=true
# Set true only when you need route snapshots stored in Postgres (can slow station search).
ELDERGO_PERSIST_ROUTE_SNAPSHOTS=false
# In-process route recommendation cache (seconds / max entries).
ELDERGO_ROUTE_CACHE_TTL_SECONDS=900
ELDERGO_ROUTE_CACHE_MAX_ENTRIES=64
ELDERGO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL (required when ELDERGO_DEMO_MODE=false)
ELDERGO_DATABASE_URL=postgresql+psycopg://eldergo:eldergo@localhost:5432/eldergo_kl

# Google Maps (Directions, Places autocomplete/details)
ELDERGO_GOOGLE_MAPS_API_KEY=

# Weather (optional)
OPENWEATHER_API_KEY=

# Gemini — key pool (at least one required for AI answers)
ELDERGO_GEMINI_MODEL=gemini-2.5-flash
ELDERGO_GEMINI_API_KEY_PRIMARY=
ELDERGO_GEMINI_API_KEY_SECONDARY=
# Additional keys, comma-separated (optional)
ELDERGO_GEMINI_API_KEYS=

# Lightweight Gemini JSON intent/slot extraction (route planning)
ELDERGO_GEMINI_INTENT_ROUTING_ENABLED=true

# AI guardrails
ELDERGO_AI_GUARDRAIL_ENABLED=true
ELDERGO_AI_GUARDRAIL_MODE=hybrid
ELDERGO_AI_GUARDRAIL_STRICT=false
