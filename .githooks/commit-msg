#!/bin/sh
# Reject Cursor co-author trailers on commits to this repository.
if grep -q '^Co-authored-by: Cursor <cursoragent@cursor.com>$' "$1"; then
  sed -i.bak '/^Co-authored-by: Cursor <cursoragent@cursor.com>$/d' "$1" 2>/dev/null \
    || sed -i '' '/^Co-authored-by: Cursor <cursoragent@cursor.com>$/d' "$1" 2>/dev/null \
    || sed '/^Co-authored-by: Cursor <cursoragent@cursor.com>$/d' "$1" >"$1.tmp" && mv "$1.tmp" "$1"
fi
exit 0
